generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Contacto {
  id                 Int      @id @default(autoincrement())
  nombre             String
  email              String
  telefono           String
  aceptaPromociones  Boolean  @default(false)
  pregunta           String?
  fechaCreacion      DateTime @default(now())
  fechaActualizacion DateTime @updatedAt

  @@map("contactos")
}

model Producto {
  id                 Int      @id @default(autoincrement())
  nombre             String
  categoria          String   @db.VarChar(255)
  descripcion        String
  precio             Decimal  @db.Decimal(10, 2)
  imagenUrl          String
  activo             Boolean  @default(true)
  visible            Boolean  @default(true)
  fechaCreacion      DateTime @default(now())
  fechaActualizacion DateTime @updatedAt
  cotizacionDetalles CotizacionDetalle[]

  @@map("productos")
}

model ContactoWhats {
  id            Int      @id @default(autoincrement())
  nombre        String?
  cotizacion    String
  clienteEstatus String  @default("pendiente") @db.VarChar(100)
  fechaEntregaEstimada DateTime? @db.Date
  fechaCreacion DateTime @default(now())
  detalles      CotizacionDetalle[]

  @@map("contactos_whats")
}

model CotizacionDetalle {
  id           Int          @id @default(autoincrement())
  idPedido     Int
  idProducto   Int
  numeroPiezas Int
  pedido       ContactoWhats @relation(fields: [idPedido], references: [id], onDelete: Cascade)
  producto     Producto     @relation(fields: [idProducto], references: [id], onDelete: Restrict)

  @@index([idPedido])
  @@index([idProducto])
  @@map("cotizacion_detalle")
}

model UsuarioAcceso {
  id                 Int            @id @default(autoincrement())
  nombreUsuario      String         @unique
  contrasenaHash     String
  nombreCompleto     String
  tienePermiso       Boolean        @default(true)
  fechaCreacion      DateTime       @default(now())
  fechaActualizacion DateTime       @updatedAt
  iniciosSesion      InicioSesion[]

  @@map("usuarios_acceso")
}

model InicioSesion {
  id            Int           @id @default(autoincrement())
  idUsuario     Int
  fechaCreacion DateTime      @default(now())
  usuario       UsuarioAcceso @relation(fields: [idUsuario], references: [id], onDelete: Cascade)

  @@index([idUsuario])
  @@map("inicios_sesion")
}

model LogError {
  id              Int      @id @default(autoincrement())
  dominio         String   @db.VarChar(120)
  origen          String?  @db.VarChar(255)
  metodo          String?  @db.VarChar(20)
  codigo          String?  @db.VarChar(100)
  mensaje         String
  detalle         String?
  contexto        String?
  fechaOcurrencia DateTime @default(now())
  fechaCreacion   DateTime @default(now())

  @@index([dominio, fechaOcurrencia])
  @@index([fechaOcurrencia])
  @@map("logs_errores")
}
