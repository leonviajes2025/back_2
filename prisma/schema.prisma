generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Contacto {
  id                 Int      @id @default(autoincrement())
  nombre             String
  email              String
  telefono           String
  aceptaPromociones  Boolean  @default(false)
  pregunta           String?
  fechaCreacion      DateTime @default(now())
  fechaActualizacion DateTime @updatedAt

  @@map("contactos")
}

model Producto {
  id                 Int      @id @default(autoincrement())
  nombre             String
  categoria          String   @db.VarChar(255)
  descripcion        String
  precio             Decimal  @db.Decimal(10, 2)
  imagenUrl          String
  activo             Boolean  @default(true)
  fechaCreacion      DateTime @default(now())
  fechaActualizacion DateTime @updatedAt
  cotizacionDetalles CotizacionDetalle[]

  @@map("productos")
}

model ContactoWhats {
  id            Int      @id @default(autoincrement())
  nombre        String?
  cotizacion    String
  fechaCreacion DateTime @default(now())
  detalles      CotizacionDetalle[]

  @@map("contactos_whats")
}

model CotizacionDetalle {
  id           Int          @id @default(autoincrement())
  idPedido     Int
  idProducto   Int
  numeroPiezas Int
  pedido       ContactoWhats @relation(fields: [idPedido], references: [id], onDelete: Cascade)
  producto     Producto     @relation(fields: [idProducto], references: [id], onDelete: Restrict)

  @@index([idPedido])
  @@index([idProducto])
  @@map("cotizacion_detalle")
}
