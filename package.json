{
  "name": "back-2",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3000",
    "sync:api-docs": "node scripts/sync-api-docs.mjs",
    "check:api-docs": "node scripts/sync-api-docs.mjs --check",
    "predev": "node ./scripts/ensure-port-3000.js && npm run preflight && npm run sync:api-docs",
    "preflight": "npm run check:db",
    "build": "prisma generate && next build",
    "vercel-build": "npm run build",
    "prebuild": "npm run sync:api-docs",
    "start": "next start -p 3000",
    "prestart": "node ./scripts/ensure-port-3000.js && npm run sync:api-docs",
    "prelint": "npm run sync:api-docs",
    "lint": "eslint .",
    "test": "vitest run",
    "check:db": "node scripts/check-db-connection.mjs",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "prisma:seed": "node prisma/seed.mjs"
  },
  "dependencies": {
    "@prisma/client": "6.18.0",
    "next": "16.2.2",
    "@supabase/supabase-js": "^2.38.3",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@eslint/eslintrc": "3.3.1",
    "@types/node": "24.6.0",
    "@types/react": "19.2.2",
    "@types/react-dom": "19.2.2",
    "eslint": "9.36.0",
    "eslint-config-next": "16.2.2",
    "prisma": "6.18.0",
    "typescript": "5.9.3",
    "vitest": "^3.2.4",
    "kill-port": "^1.6.1"
  },
  "engines": {
    "node": "^20.0.0 || ^22.0.0 || ^24.0.0"
  }
}
