{
  "info": {
    "name": "back_2 API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Coleccion generada desde data/api-docs.json para mantener sincronizados front y Postman."
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://127.0.0.1:3000"
    },
    {
      "key": "contactoEmailDuplicado",
      "value": "marta.duplicado.postman@example.com"
    },
    {
      "key": "productoId",
      "value": "1"
    },
    {
      "key": "pedidoId",
      "value": "1"
    },
    {
      "key": "usuarioAccesoId",
      "value": "1"
    },
    {
      "key": "nombreUsuarioAccesoAdmin",
      "value": "admin"
    },
    {
      "key": "contrasenaAccesoAdmin",
      "value": "Admin123"
    },
    {
      "key": "nombreUsuarioAccesoNuevo",
      "value": "supervisor"
    },
    {
      "key": "contrasenaAccesoNueva",
      "value": "Supervisor123"
    }
  ],
  "item": [
    {
      "name": "Contactos",
      "item": [
        {
          "name": "GET Listar contactos",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/contactos"
          }
        },
        {
          "name": "POST Crear contacto",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/contactos",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Marta Soto\",\n  \"email\": \"{{contactoEmailDuplicado}}\",\n  \"telefono\": \"+5215555555510\",\n  \"aceptaPromociones\": true,\n  \"pregunta\": \"Tienen disponibilidad inmediata?\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Productos",
      "item": [
        {
          "name": "GET Listar productos",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/productos"
          }
        },
        {
          "name": "POST Crear producto",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/productos",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Producto Postman\",\n  \"categoria\": \"Accesorios\",\n  \"descripcion\": \"Creado desde la coleccion de Postman\",\n  \"precio\": \"220.00\",\n  \"imagenUrl\": \"https://example.com/postman.jpg\",\n  \"activo\": true,\n  \"visible\": true\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const response = pm.response.json();",
                  "if (response.id) {",
                  "  pm.collectionVariables.set('productoId', String(response.id));",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "GET Listar productos activos",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/productos/activos"
          }
        },
        {
          "name": "GET Listar productos visibles",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/productos/visibles"
          }
        },
        {
          "name": "PUT Actualizar producto",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/api/productos/{{productoId}}",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Producto Actualizado Postman\",\n  \"categoria\": \"Hogar\",\n  \"precio\": \"180.00\",\n  \"visible\": false\n}"
            }
          }
        },
        {
          "name": "DELETE Desactivar producto",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/api/productos/{{productoId}}"
          }
        }
      ]
    },
    {
      "name": "Contactos WhatsApp",
      "item": [
        {
          "name": "GET Listar solicitudes WhatsApp",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/contactos-whats"
          }
        },
        {
          "name": "POST Crear solicitud WhatsApp",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/contactos-whats",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": null,\n  \"cotizacion\": \"Necesito una cotizacion para 20 piezas del Producto Base\",\n  \"clienteEstatus\": \"pendiente\",\n  \"fechaEntregaEstimada\": \"2026-04-20\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const response = pm.response.json();",
                  "if (response.id) {",
                  "  pm.collectionVariables.set('pedidoId', String(response.id));",
                  "}"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Cotizacion Detalle",
      "item": [
        {
          "name": "POST Crear detalle de cotizacion",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/cotizacion-detalle",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"idPedido\": {{pedidoId}},\n  \"idProducto\": {{productoId}},\n  \"numeroPiezas\": 20\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Acceso Administrativo",
      "item": [
        {
          "name": "GET Listar usuarios de acceso",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/usuarios-acceso"
          }
        },
        {
          "name": "POST Crear usuario de acceso",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/usuarios-acceso",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombreUsuario\": \"{{nombreUsuarioAccesoNuevo}}\",\n  \"contrasena\": \"{{contrasenaAccesoNueva}}\",\n  \"nombreCompleto\": \"Supervisor Comercial\",\n  \"tienePermiso\": true\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const response = pm.response.json();",
                  "if (response.id) {",
                  "  pm.collectionVariables.set('usuarioAccesoId', String(response.id));",
                  "}",
                  "if (response.nombreUsuario) {",
                  "  pm.collectionVariables.set('nombreUsuarioAccesoNuevo', response.nombreUsuario);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "PUT Actualizar usuario de acceso",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/api/usuarios-acceso/{{usuarioAccesoId}}",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombreCompleto\": \"Supervisor Ventas\",\n  \"tienePermiso\": false,\n  \"contrasena\": \"NuevaClave123\"\n}"
            }
          }
        },
        {
          "name": "POST Validar acceso administrativo",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/usuarios-acceso/validar",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombreUsuario\": \"{{nombreUsuarioAccesoAdmin}}\",\n  \"contrasena\": \"{{contrasenaAccesoAdmin}}\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Inicios de Sesion",
      "item": [
        {
          "name": "POST Registrar inicio de sesion",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/inicios-sesion",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombreUsuario\": \"{{nombreUsuarioAccesoAdmin}}\",\n  \"contrasena\": \"{{contrasenaAccesoAdmin}}\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Logs de Errores",
      "item": [
        {
          "name": "GET Listar logs de errores",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/logs-errores"
          }
        },
        {
          "name": "POST Crear log de error",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/logs-errores",
            "header": [
              {
